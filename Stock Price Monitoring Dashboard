#include <iostream>
#include <vector>
using namespace std;

struct Stock {
    string name;
    float price;
};

vector<Stock> stocks;

// Add stock
void addStock() {
    Stock s;
    cout << "Enter stock name: ";
    cin >> s.name;
    cout << "Enter stock price: ";
    cin >> s.price;

    stocks.push_back(s);
    cout << "Stock added successfully!\n";
}

// Display stocks
void displayStocks() {
    if (stocks.empty()) {
        cout << "No stocks available!\n";
        return;
    }

    cout << "\nStock List:\n";
    for (int i = 0; i < stocks.size(); i++) {
        cout << i + 1 << ". " << stocks[i].name
             << " - Price: " << stocks[i].price << endl;
    }
}

// Update stock price
void updateStock() {
    string name;
    cout << "Enter stock name to update: ";
    cin >> name;

    for (int i = 0; i < stocks.size(); i++) {
        if (stocks[i].name == name) {
            cout << "Enter new price: ";
            cin >> stocks[i].price;
            cout << "Updated successfully!\n";
            return;
        }
    }

    cout << "Stock not found!\n";
}

// Delete stock
void deleteStock() {
    string name;
    cout << "Enter stock name to delete: ";
    cin >> name;

    for (int i = 0; i < stocks.size(); i++) {
        if (stocks[i].name == name) {
            stocks.erase(stocks.begin() + i);
            cout << "Deleted successfully!\n";
            return;
        }
    }

    cout << "Stock not found!\n";
}

int main() {
    int choice;

    do {
        cout << "\n--- Stock Dashboard ---\n";
        cout << "1. Add Stock\n";
        cout << "2. Display Stocks\n";
        cout << "3. Update Stock\n";
        cout << "4. Delete Stock\n";
        cout << "5. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {
            case 1: addStock(); break;
            case 2: displayStocks(); break;
            case 3: updateStock(); break;
            case 4: deleteStock(); break;
            case 5: cout << "Exiting...\n"; break;
            default: cout << "Invalid choice!\n";
        }

    } while (choice != 5);

    return 0;
}
